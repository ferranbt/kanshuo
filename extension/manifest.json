{
  "manifest_version": 3,
  "name": "Kanshuo Video Detector",
  "version": "1.1",
  "description": "Detects YouTube and Bilibili video playback and sends notifications to local server for subtitle translation",
  "permissions": [
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "ws://localhost:8080/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "overlay.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
